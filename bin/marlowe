#!/usr/bin/env bash
set -euo pipefail

MARLOWE_HOME="${MARLOWE_HOME:-$HOME/.marlowe}"

# Self-locate the framework from this script's resolved path. Works whether
# marlowe is invoked directly from a checkout, via an install.sh symlink, or
# via a custom symlink pointing anywhere. Falls back to $HOME/.marlowe-framework
# if readlink -f is unavailable (e.g. stock macOS without coreutils).
if [ -z "${MARLOWE_FRAMEWORK:-}" ]; then
  _marlowe_bin="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]}")"
  if [ -n "$_marlowe_bin" ] && [ -f "$_marlowe_bin" ]; then
    MARLOWE_FRAMEWORK="$(cd "$(dirname "$_marlowe_bin")/.." 2>/dev/null && pwd)"
  fi
  : "${MARLOWE_FRAMEWORK:=$HOME/.marlowe-framework}"
fi

# Export so adapter scripts (and any other child process) inherit the right
# values. Plain assignment above doesn't propagate beyond bin/marlowe itself.
export MARLOWE_HOME MARLOWE_FRAMEWORK

PINK=$'\033[38;2;254;1;154m'
DIM=$'\033[2m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

say()  { printf '%s⟡ marlowe%s %s\n' "$PINK" "$RESET" "$*"; }
ok()   { printf '  %s✓%s %s\n' "$PINK" "$RESET" "$*"; }
step() { printf '\n%s%s%s\n' "$BOLD" "$*" "$RESET"; }
die()  { printf '%s⟡ marlowe%s %s\n' "$PINK" "$RESET" "$*" >&2; exit 1; }

ask() {
  # ask <prompt> <default>  → echoes the answer
  local prompt="$1" default="${2:-}" reply
  if [ -n "$default" ]; then
    read -rp "  $prompt [$default]: " reply
    printf '%s' "${reply:-$default}"
  else
    read -rp "  $prompt: " reply
    printf '%s' "$reply"
  fi
}

confirm() {
  # confirm <prompt>  → returns 0 for yes
  local reply
  read -rp "  $1 [Y/n]: " reply
  case "${reply:-Y}" in Y|y|yes|YES) return 0 ;; *) return 1 ;; esac
}

_bump() {
  # _bump <counter-key> — best-effort atomic-ish increment in a flat file.
  # Runs on the fast path (cmd_activity); keep it fast and silent-on-failure.
  local key="$1"
  [ -n "$key" ] || return 0
  [ -d "$MARLOWE_HOME" ] || return 0
  local f="$MARLOWE_HOME/.counters"
  touch "$f" 2>/dev/null || return 0
  awk -v k="$key" '
    BEGIN { found = 0 }
    $1 == k { print $1, $2 + 1; found = 1; next }
    { print }
    END { if (!found) print k, 1 }
  ' "$f" > "$f.tmp" 2>/dev/null && mv "$f.tmp" "$f" 2>/dev/null || true
}

_with_lock() {
  # _with_lock <fn> [args…]  — serialize write-side commands per host.
  # Lock lives inside $MARLOWE_HOME/.git/ so git ignores it automatically;
  # falls back to $MARLOWE_HOME/.lock if the data repo isn't initialized yet.
  local fn="$1"; shift
  local lockdir lockfile
  if [ -d "$MARLOWE_HOME/.git" ]; then
    lockdir="$MARLOWE_HOME/.git"
  else
    mkdir -p "$MARLOWE_HOME"
    lockdir="$MARLOWE_HOME"
  fi
  lockfile="$lockdir/marlowe.lock"
  touch "$lockfile"
  (
    if ! flock -w 10 -x 9; then
      say "another marlowe operation is running — try again shortly"
      exit 1
    fi
    "$fn" "$@"
  ) 9<"$lockfile"
}

cmd_init() {
  local force=0
  [ "${1:-}" = "--force" ] && force=1

  if [ -f "$MARLOWE_HOME/preferences.md" ] && [ $force -eq 0 ]; then
    die "already initialized at $MARLOWE_HOME. use 'marlowe edit' or re-run with --force."
  fi

  say "init wizard"

  # 1. Identity
  step "1/4  Identity"
  local user_name assistant_name
  user_name="$(ask 'your name' "$(whoami)")"
  assistant_name="$(ask 'assistant name' 'Marlowe')"

  # 2. Data repo
  step "2/4  Data repo"
  echo "  marlowe keeps your preferences in a private git repo."
  echo "    (a) clone existing URL"
  echo "    (b) create new private GitHub repo via 'gh'"
  echo "    (c) start empty (no remote — add one later)"
  local choice data_url new_slug
  choice="$(ask 'choice (a/b/c)' 'c')"
  case "$choice" in
    a) data_url="$(ask 'repo URL')" ;;
    b)
      command -v gh >/dev/null || die "'gh' not found on PATH"
      new_slug="$(ask 'new repo slug (e.g. you/marlowe-data)')"
      ;;
    c) : ;;
    *) die "invalid choice: $choice" ;;
  esac

  # 3. Tools
  step "3/4  Tools"
  local tools=()
  for t in claude codex cursor; do
    local dir="$HOME/.$t"
    if [ -d "$dir" ]; then
      confirm "apply $t adapter (~/.$t detected)" && tools+=("$t")
    else
      confirm "apply $t adapter (~/.$t not detected — force)" && tools+=("$t") || true
    fi
  done

  # 4. Summary
  step "4/4  Summary"
  echo "  identity:  $user_name / $assistant_name"
  echo "  data repo: $(case "$choice" in a) echo "clone $data_url";; b) echo "create $new_slug (private)";; c) echo "empty, no remote";; esac)"
  echo "  adapters:  ${tools[*]:-<none>}"
  confirm "proceed" || die "aborted."

  # Execute
  mkdir -p "$MARLOWE_HOME"
  case "$choice" in
    a)
      git clone "$data_url" "$MARLOWE_HOME"
      ok "cloned $data_url"
      ;;
    b)
      git -C "$MARLOWE_HOME" init -q -b main
      cp "$MARLOWE_FRAMEWORK/templates/preferences.md" "$MARLOWE_HOME/preferences.md"
      _substitute_identity "$user_name" "$assistant_name"
      printf 'generated/\n' > "$MARLOWE_HOME/.gitignore"
      git -C "$MARLOWE_HOME" add .
      git -C "$MARLOWE_HOME" -c commit.gpgsign=false commit -q -m "init marlowe data"
      gh repo create "$new_slug" --private --source="$MARLOWE_HOME" --remote=origin --push \
        --description "Marlowe private context"
      ok "created private repo $new_slug and pushed"
      ;;
    c)
      git -C "$MARLOWE_HOME" init -q -b main
      cp "$MARLOWE_FRAMEWORK/templates/preferences.md" "$MARLOWE_HOME/preferences.md"
      _substitute_identity "$user_name" "$assistant_name"
      printf 'generated/\n' > "$MARLOWE_HOME/.gitignore"
      ok "started empty repo at $MARLOWE_HOME"
      ;;
  esac

  # Ensure preferences.md carries the identity (clone path may skip substitution if
  # the repo already has tokens resolved).
  if grep -q '__USER_NAME__' "$MARLOWE_HOME/preferences.md" 2>/dev/null; then
    _substitute_identity "$user_name" "$assistant_name"
    ok "substituted identity into preferences.md"
  fi

  for t in "${tools[@]}"; do
    "$MARLOWE_FRAMEWORK/adapters/$t/apply.sh"
  done

  step "done"
  cat <<EOF
  edit preferences:  marlowe edit
  re-apply all:      marlowe sync
  re-apply one:      marlowe apply <tool>
EOF
}

_substitute_identity() {
  local u="$1" a="$2"
  local f="$MARLOWE_HOME/preferences.md"
  sed -i.bak -e "s|__USER_NAME__|$u|g" -e "s|__ASSISTANT_NAME__|$a|g" "$f"
  rm -f "$f.bak"
}

cmd_sync() {
  if [ -d "$MARLOWE_HOME/.git" ]; then
    git -C "$MARLOWE_HOME" pull --ff-only 2>/dev/null || true
  fi
  for a in "$MARLOWE_FRAMEWORK"/adapters/*/apply.sh; do
    tool="$(basename "$(dirname "$a")")"
    [ -d "$HOME/.$tool" ] && "$a" || true
  done
}

cmd_apply() {
  local tool="${1:?usage: marlowe apply <claude|codex|cursor>}"
  "$MARLOWE_FRAMEWORK/adapters/$tool/apply.sh"
}

cmd_lint() {
  local warn_only=0
  [ "${1:-}" = "--warn-only" ] && warn_only=1
  local f="$MARLOWE_HOME/preferences.md"
  [ -f "$f" ] || die "no preferences.md at $f"

  local issues=0
  if grep -q '__[A-Z_]*__' "$f"; then
    printf '  %s·%s unresolved placeholders:\n' "$PINK" "$RESET"
    grep -n '__[A-Z_]*__' "$f" | head -5 | sed 's/^/    /'
    issues=$((issues + 1))
  fi
  local dupes
  dupes="$(grep -E '^- ' "$f" | grep -v '^- …$' | sort | uniq -d || true)"
  if [ -n "$dupes" ]; then
    printf '  %s·%s duplicate bullets:\n' "$PINK" "$RESET"
    printf '%s\n' "$dupes" | head -5 | sed 's/^/    /'
    issues=$((issues + 1))
  fi
  if ! head -1 "$f" | grep -q '^---$'; then
    printf '  %s·%s missing YAML frontmatter\n' "$PINK" "$RESET"
    issues=$((issues + 1))
  fi

  # Drift: adapted files should contain the current capture protocol block.
  # If a marlowe:begin marker exists but the block doesn't, the apply is stale.
  for pair in "claude:$HOME/.claude/CLAUDE.md" "codex:$HOME/.codex/AGENTS.md"; do
    local tool dest
    tool="${pair%%:*}"; dest="${pair#*:}"
    if [ -f "$dest" ] && grep -q '<!-- marlowe:begin -->' "$dest" 2>/dev/null; then
      if ! grep -q '^# Capture protocol' "$dest" 2>/dev/null; then
        printf '  %s·%s %s is stale (no capture protocol) — run: marlowe apply %s\n' \
          "$PINK" "$RESET" "$dest" "$tool"
        issues=$((issues + 1))
      fi
    fi
  done

  if [ $issues -eq 0 ]; then
    ok "preferences.md: clean"
    return 0
  fi
  [ $warn_only -eq 1 ] && return 0
  return 1
}

cmd_save() {
  local message="" quiet=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --quiet)     quiet=1; shift ;;
      --if-dirty)  shift ;;   # accepted for clarity; save is already a no-op when clean
      -m)          message="${2:-}"; shift 2 ;;
      *)           message="$1"; shift ;;
    esac
  done
  [ -d "$MARLOWE_HOME/.git" ] || die "no git in $MARLOWE_HOME — run 'marlowe init'"

  # Lint, warn only — don't block saves on stylistic issues.
  cmd_lint --warn-only >/dev/null 2>&1 || true

  if [ -z "$(git -C "$MARLOWE_HOME" status --porcelain 2>/dev/null)" ]; then
    [ $quiet -eq 0 ] && say "nothing to save"
  else
    local msg="${message:-update preferences}"
    git -C "$MARLOWE_HOME" add -A
    git -C "$MARLOWE_HOME" -c commit.gpgsign=false commit -q -m "$msg"
    [ $quiet -eq 0 ] && ok "committed: $msg"
  fi

  # Push — best effort. Offline / no-remote => warn and continue.
  if git -C "$MARLOWE_HOME" remote get-url origin >/dev/null 2>&1; then
    local branch
    branch="$(git -C "$MARLOWE_HOME" rev-parse --abbrev-ref HEAD)"
    if git -C "$MARLOWE_HOME" push -q origin "$branch" 2>/dev/null; then
      [ $quiet -eq 0 ] && ok "pushed origin/$branch"
    else
      say "push failed (offline?) — will retry on next save"
    fi
  fi

  # Re-apply adapters so the tools see the new state.
  for a in "$MARLOWE_FRAMEWORK"/adapters/*/apply.sh; do
    local tool
    tool="$(basename "$(dirname "$a")")"
    [ -d "$HOME/.$tool" ] && "$a" >/dev/null || true
  done
}

cmd_add() {
  local type="${1:-}"; shift || true
  local content="$*"
  case "$type" in
    lingo|ai-lingo|preference|project) ;;
    *) die "usage: marlowe add <lingo|ai-lingo|preference|project> <text…>" ;;
  esac
  [ -n "$content" ] || die "missing content"

  local f="$MARLOWE_HOME/preferences.md"
  [ -f "$f" ] || die "no preferences.md — run 'marlowe init'"

  local section
  case "$type" in
    lingo)      section='## Lingo I use' ;;
    ai-lingo)   section='## Lingo I want the AI to use' ;;
    preference) section='## Standing preferences' ;;
    project)    section="## Projects I'm working on" ;;
  esac

  awk -v s="$section" -v line="- $content" '
    BEGIN { inside = 0; inserted = 0 }
    {
      if ($0 == s) { inside = 1; print; next }
      if (inside && !inserted && /^## / && $0 != s) {
        print line; inserted = 1; inside = 0; print; next
      }
      if (inside && !inserted && $0 == "- …") {
        print line; inserted = 1; next
      }
      print
    }
    END { if (inside && !inserted) print line }
  ' "$f" > "$f.tmp" && mv "$f.tmp" "$f"

  ok "added to $type: $content"
  _bump "add.$type"
  cmd_save "add $type: $content" --quiet
}

_project_active_name() {
  # Precedence: explicit override (.active-project) > $PWD longest-path match.
  local f="$MARLOWE_HOME/projects.md"
  [ -f "$f" ] || return 0
  local marker="$MARLOWE_HOME/.active-project"
  if [ -f "$marker" ]; then
    local override
    override="$(head -1 "$marker" 2>/dev/null | sed 's/^ *//;s/ *$//')"
    if [ -n "$override" ] && grep -qE "^- *$override *\|" "$f" 2>/dev/null; then
      printf '%s' "$override"; return 0
    fi
  fi
  local pwd_abs
  pwd_abs="$(pwd -P 2>/dev/null)" || return 0
  local best_name="" best_len=0
  while IFS='|' read -r _name _path _rest; do
    _name="${_name#- }"
    _name="$(printf '%s' "$_name" | sed 's/^ *//;s/ *$//')"
    _path="$(printf '%s' "$_path" | sed 's/^ *//;s/ *$//')"
    _path="${_path/#\~/$HOME}"
    [ -n "$_path" ] || continue
    case "$pwd_abs" in
      "$_path"|"$_path"/*)
        if [ ${#_path} -gt $best_len ]; then
          best_len=${#_path}
          best_name="$_name"
        fi
        ;;
    esac
  done < <(grep -E '^- ' "$f" 2>/dev/null || true)
  printf '%s' "$best_name"
}

cmd_project() {
  local sub="${1:-list}"; shift || true
  case "$sub" in
    add)      _project_add      "$@" ;;
    list)     _project_list     "$@" ;;
    active)   _project_show_active "$@" ;;
    remove|rm) _project_remove  "$@" ;;
    brief)    _project_brief    "$@" ;;
    activate) _project_activate "$@" ;;
    *) die "usage: marlowe project <add|list|active|remove|brief|activate>" ;;
  esac
}

_project_add() {
  local from_cwd=0
  [ "${1:-}" = "--from-cwd" ] && from_cwd=1

  local name path git brief
  if [ $from_cwd -eq 1 ]; then
    path="$(pwd -P)"
    name="$(basename "$path")"
    git="$(git -C "$path" config --get remote.origin.url 2>/dev/null \
            | sed -E 's|^https://||; s|^git@||; s|\.git$||; s|:|/|')"
    [ -n "$git" ] || git="-"
  else
    name="$(ask 'name')"
    path="$(ask 'path (absolute or ~/...)')"
    git="$(ask 'git (e.g. github.com/owner/repo)' '-')"
  fi
  brief="$(ask 'brief (≤80 chars)')"
  brief="${brief:0:80}"

  local f="$MARLOWE_HOME/projects.md"
  if [ ! -f "$f" ]; then
    cat > "$f" <<'EOF'
# Projects

<!-- managed via `marlowe project add|list`. Format: -->
<!-- - name | path | git | brief (≤80 chars) -->

EOF
  fi

  if grep -qE "^- *$name *\|" "$f" 2>/dev/null; then
    die "project '$name' already in $f"
  fi
  printf -- '- %s | %s | %s | %s\n' "$name" "$path" "$git" "$brief" >> "$f"
  ok "added project: $name  ($path)"
  _bump "project.add"
  cmd_save "project: add $name" --quiet
}

_project_list() {
  local f="$MARLOWE_HOME/projects.md"
  [ -f "$f" ] || { say "no projects.md — run: marlowe project add --from-cwd"; return 0; }
  local active
  active="$(_project_active_name)"
  grep -E '^- ' "$f" | while IFS='|' read -r n p g b; do
    n="${n#- }"
    n="$(printf '%s' "$n" | sed 's/^ *//;s/ *$//')"
    p="$(printf '%s' "$p" | sed 's/^ *//;s/ *$//')"
    b="$(printf '%s' "$b" | sed 's/^ *//;s/ *$//')"
    if [ "$n" = "$active" ]; then
      printf '  %s●%s %-12s %s  %s\n' "$PINK" "$RESET" "$n" "$p" "$b"
    else
      printf '    %-12s %s  %s\n' "$n" "$p" "$b"
    fi
  done
}

_project_show_active() {
  local a
  a="$(_project_active_name)"
  if [ -n "$a" ]; then
    printf '%s\n' "$a"
  else
    say "no active project at $(pwd -P)"
    return 1
  fi
}

_project_remove() {
  local name="${1:?usage: marlowe project remove <name>}"
  local f="$MARLOWE_HOME/projects.md"
  [ -f "$f" ] || die "no projects.md"
  grep -qE "^- *$name *\|" "$f" || die "project '$name' not found"
  local tmp="$f.tmp"
  awk -v n="$name" '
    /^- / {
      split($0, parts, "|"); nm = parts[1]; sub(/^- */, "", nm); sub(/ *$/, "", nm);
      if (nm == n) next
    }
    { print }
  ' "$f" > "$tmp" && mv "$tmp" "$f"
  ok "removed project: $name"
  _bump "project.remove"
  cmd_save "project: remove $name" --quiet
}

_project_brief() {
  local name="${1:?usage: marlowe project brief <name> <new-brief>}"; shift
  local new_brief="$*"
  [ -n "$new_brief" ] || die "missing new brief"
  new_brief="${new_brief:0:80}"
  local f="$MARLOWE_HOME/projects.md"
  [ -f "$f" ] || die "no projects.md"
  local found=0 tmp="$f.tmp"
  : > "$tmp"
  while IFS= read -r line; do
    case "$line" in
      "- "*)
        local rest="${line#- }"
        IFS='|' read -r _n _p _g _b <<< "$rest"
        local tn
        tn="$(printf '%s' "$_n" | sed 's/^ *//;s/ *$//')"
        if [ "$tn" = "$name" ]; then
          local tp tg
          tp="$(printf '%s' "$_p" | sed 's/^ *//;s/ *$//')"
          tg="$(printf '%s' "$_g" | sed 's/^ *//;s/ *$//')"
          printf -- '- %s | %s | %s | %s\n' "$tn" "$tp" "$tg" "$new_brief" >> "$tmp"
          found=1
        else
          printf '%s\n' "$line" >> "$tmp"
        fi
        ;;
      *) printf '%s\n' "$line" >> "$tmp" ;;
    esac
  done < "$f"
  [ $found -eq 1 ] || { rm -f "$tmp"; die "project '$name' not found"; }
  mv "$tmp" "$f"
  ok "updated brief for $name"
  _bump "project.brief"
  cmd_save "project: brief $name" --quiet
}

_project_activate() {
  local arg="${1:-}"
  local marker="$MARLOWE_HOME/.active-project"
  if [ -z "$arg" ] || [ "$arg" = "--clear" ]; then
    rm -f "$marker"
    ok "cleared override — \$PWD matching resumes"
    return 0
  fi
  local f="$MARLOWE_HOME/projects.md"
  [ -f "$f" ] || die "no projects.md"
  grep -qE "^- *$arg *\|" "$f" || die "project '$arg' not found"
  printf '%s\n' "$arg" > "$marker"
  ok "active-project override: $arg  (clear: marlowe project activate --clear)"
  _bump "project.activate"
}

cmd_activity() {
  # Fast, lockless append. Single-line appends are atomic on POSIX.
  # Runs zero-cost on the common path — called from shell hook / git hook.
  local msg="$*"
  [ -n "$msg" ] || return 0
  [ -d "$MARLOWE_HOME" ] || return 0
  local f="$MARLOWE_HOME/activities.md"
  printf '[%s] [%s] %s\n' "$(date -Iseconds)" "$(hostname -s)" "$msg" >> "$f" 2>/dev/null || true
  _bump activity
}

cmd_wire() {
  # Idempotent installer for automation hooks: shell (B1) + git post-commit (B2).
  local shellrc="${1:-$HOME/.bashrc}"
  local source_line="[ -f \"$MARLOWE_FRAMEWORK/shell/marlowe.sh\" ] && . \"$MARLOWE_FRAMEWORK/shell/marlowe.sh\""

  # 1. Shell hook
  if [ ! -f "$shellrc" ]; then
    die "no shell rc at $shellrc — pass path as arg or create it"
  fi
  if grep -qF "$MARLOWE_FRAMEWORK/shell/marlowe.sh" "$shellrc" 2>/dev/null; then
    ok "shell hook already present in $shellrc"
  else
    printf '\n# marlowe: log repo entries as activities\n%s\n' "$source_line" >> "$shellrc"
    ok "added shell hook -> $shellrc (reload with: source $shellrc)"
  fi

  # 2. Git hook (via core.hooksPath)
  local target="$MARLOWE_FRAMEWORK/hooks"
  local current
  current="$(git config --global --get core.hooksPath 2>/dev/null || true)"
  if [ -z "$current" ]; then
    git config --global core.hooksPath "$target"
    ok "set global core.hooksPath -> $target"
  elif [ "$current" = "$target" ]; then
    ok "global core.hooksPath already -> $target"
  else
    say "core.hooksPath is set to: $current"
    say "  not overriding. to enable marlowe git hooks, either:"
    say "    (a) copy $target/post-commit into $current/"
    say "    (b) git config --global core.hooksPath $target  (replaces current)"
  fi

  # 3. Gitignore activities log + archive + counters (all local-only)
  local gi="$MARLOWE_HOME/.gitignore"
  if [ -f "$gi" ]; then
    if ! grep -qE '^activities\.md\*$' "$gi"; then
      sed -i '/^activities\.md$/d' "$gi" 2>/dev/null || true
      echo "activities.md*" >> "$gi"
      ok "ignored activities.md* in $gi"
    fi
    if ! grep -qE '^\.counters$' "$gi"; then
      echo ".counters" >> "$gi"
      ok "ignored .counters in $gi"
    fi
    if ! grep -qE '^\.active-project$' "$gi"; then
      echo ".active-project" >> "$gi"
      ok "ignored .active-project in $gi"
    fi
    if ! grep -qE '^drafts\.md$' "$gi"; then
      echo "drafts.md" >> "$gi"
      ok "ignored drafts.md in $gi"
    fi
  fi
}

cmd_distill() {
  # B3: LLM pass that promotes raw activities -> durable memory bullets.
  # Flags:
  #   --if-over N   — skip if raw line count < N (cron-friendly: cheap no-op on quiet weeks)
  local min_lines=1
  while [ $# -gt 0 ]; do
    case "$1" in
      --if-over) min_lines="${2:?--if-over needs a number}"; shift 2 ;;
      *)         shift ;;
    esac
  done
  local activities="$MARLOWE_HOME/activities.md"
  local memory="$MARLOWE_HOME/memory.md"
  [ -f "$activities" ] || { say "no activities.md — nothing to distill"; return 0; }
  local lines
  lines="$(grep -c '^\[' "$activities" 2>/dev/null || echo 0)"
  [ "$lines" -gt 0 ] || { say "activities.md is empty — nothing to distill"; return 0; }
  if [ "$lines" -lt "$min_lines" ]; then
    say "activities.md has $lines lines (threshold $min_lines) — skipping"
    return 0
  fi
  command -v claude >/dev/null || die "'claude' CLI not on PATH — install Claude Code to use distill"

  say "distilling $lines activity lines..."

  local prompt
  prompt="$(cat <<EOF
You are compressing a raw activity log into durable memory.

Input: timestamped entries of the form \`[ts] [host] msg\` — shell repo entries
and git commits logged automatically.

Task: output 1-3 bullets (each <120 chars) capturing durable, cross-session-useful
narrative. Prefer project-level framing ("iterated on marlowe adapter layer",
"shipped v0.7 automation") over granular events. Drop SHAs, timestamps, host names.

If nothing is durable, output exactly: NONE

Output plain "- " bullets, no preamble, no trailing text.

Activity log:
$(cat "$activities")
EOF
)"

  local summary
  summary="$(printf '%s' "$prompt" | claude -p 2>/dev/null | sed '/^$/d')"

  if [ -z "$summary" ] || [ "$summary" = "NONE" ]; then
    say "no durable facts extracted — activities.md left intact"
    return 0
  fi

  local date_str
  date_str="$(date +%Y-%m-%d)"
  {
    printf '\n## Distilled %s\n' "$date_str"
    printf '%s\n' "$summary"
  } >> "$memory"

  # Archive raw log before reset (local-only; never committed)
  mv "$activities" "$activities.last"
  : > "$activities"

  ok "distilled $lines activities -> memory.md (raw kept at $activities.last)"
  _bump distill
  cmd_save "distill: $lines activities -> memory" --quiet
}

cmd_remember() {
  local fact="$*"
  [ -n "$fact" ] || die "usage: marlowe remember \"<fact>\""
  local f="$MARLOWE_HOME/memory.md"
  if [ ! -f "$f" ]; then
    printf '# Memory\n\n' > "$f"
  fi
  local date_str
  date_str="$(date +%Y-%m-%d)"
  printf -- '- [%s] %s\n' "$date_str" "$fact" >> "$f"
  ok "remembered: $fact"
  _bump remember
  cmd_save "remember: $fact" --quiet
}

_smart_review() {
  # Smart-review core: LLM proposes a revised memory.md that (a) integrates
  # drafts + recent activity-extracted bullets as new entries, (b) tags
  # untagged entries, (c) culls obsolete/duplicate/test-fixture entries.
  # The user reviews the complete proposal in $EDITOR before it replaces
  # memory.md atomically. AI does the hard work; user has easy veto.
  local drafts="$1" activities="$2" memory="$3" yes_mode="$4"

  local drafts_content=""
  [ -f "$drafts" ] && drafts_content="$(grep -E '^- ' "$drafts" 2>/dev/null || true)"

  local recent=""
  [ -f "$activities" ] && recent="$(tail -50 "$activities" 2>/dev/null || true)"

  local today
  today="$(date +%Y-%m-%d)"

  say "running audit pass via claude — ~10-20s..."

  local prompt
  prompt="$(cat <<EOF
You are curating the memory.md file for a single-user cross-tool AI context
system. Your output REPLACES memory.md directly. The user will see your
proposal in an editor and can edit before applying.

Rules for the revised memory.md:

1. Keep the '# Memory' header at top.
2. Each entry is a markdown bullet: '- [YYYY-MM-DD] <text>' optionally with a
   tag: '- [YYYY-MM-DD] [tag] <text>'.
3. Tags — add to any untagged entry you can confidently classify:
   - identity  : user/assistant identity (never expires)
   - rule      : standing rules/constraints (never expires unless retracted)
   - insight   : durable design/principle observations
   - dead-end  : approaches tried that don't work (keep forever)
   - state     : short-lived status (cull candidate when stale)
   - tmp       : test fixtures, noise (cull candidate)
4. Integrate the 'New candidates' below as NEW entries dated ${today}.
   Assign them a plausible tag when you can.
5. Remove entries that are clearly obsolete, duplicate, superseded, or
   marked [smoke] / [tmp]. When in doubt, KEEP.
6. NEVER remove entries tagged [identity] or [rule] — these are load-bearing.
7. Preserve the EXACT wording of entries you keep. Do not paraphrase.
8. Group by simple section headers if useful, but don't invent new taxonomy.

Output ONLY the complete revised memory.md content. No preamble, no trailing
commentary, no code fences.

=== Current memory.md ===
$(cat "$memory" 2>/dev/null)

=== New candidates (drafts + activity-derived) ===
${drafts_content:-<none>}

=== Recent activity context ===
${recent:-<none>}
EOF
)"

  local revised
  revised="$(printf '%s' "$prompt" | claude -p 2>/dev/null || true)"

  if [ -z "$revised" ]; then
    say "claude returned nothing — memory.md unchanged. next review: marlowe review --no-audit"
    return 1
  fi

  local tmp
  tmp="$(mktemp)"
  {
    printf '# Smart Review (audit mode) — this is the PROPOSED revised memory.md\n'
    printf '# Save + close to apply (replaces memory.md atomically).\n'
    printf '# Close without saving or clear the file to abort.\n'
    printf '# Lines starting with # are stripped before applying.\n'
    printf '#\n'
    printf '%s\n' "$revised"
  } > "$tmp"

  local prev_size prev_count new_size new_count
  prev_size="$(wc -c < "$memory" 2>/dev/null || echo 0)"
  prev_count="$(grep -cE '^- ' "$memory" 2>/dev/null || echo 0)"
  new_size="$(wc -c <<< "$revised")"
  new_count=0
  if grep -qE '^- ' <<< "$revised" 2>/dev/null; then
    new_count="$(grep -cE '^- ' <<< "$revised")"
  fi

  say "proposal: ${prev_count} -> ${new_count} entries, ${prev_size}B -> ${new_size}B"
  say "opening \${EDITOR:-vi} — prune freely, save to apply"

  if [ "$yes_mode" -eq 0 ]; then
    "${EDITOR:-vi}" "$tmp"
  fi

  # Strip comment lines
  grep -v '^#' "$tmp" > "$tmp.clean" 2>/dev/null || true
  mv "$tmp.clean" "$tmp"

  # Abort cleanly if user cleared everything meaningful
  if ! grep -qE '^- ' "$tmp" 2>/dev/null; then
    rm -f "$tmp"
    say "no entries remain after edit — aborting, memory.md unchanged"
    return 1
  fi

  # Atomic replace
  mv "$tmp" "$memory"
  ok "memory.md updated by smart review (${prev_count} -> $(grep -cE '^- ' "$memory" || echo 0) entries)"

  # Drafts were folded into the revised memory.md — clear them
  printf '# Drafts — run `marlowe review` to promote to memory.md\n\n' > "$drafts"

  _bump review
  cmd_save "smart review: ${prev_count} -> $(grep -cE '^- ' "$memory" || echo 0) entries" --quiet
}

cmd_draft() {
  # Fast, lockless append to drafts.md. Called proactively by the AI (via
  # capture protocol) or by the user. Drafts are gitignored — they don't
  # cross into memory until the user runs `marlowe review`.
  local text="$*"
  [ -n "$text" ] || die "usage: marlowe draft <text>"
  [ -d "$MARLOWE_HOME" ] || return 0
  local f="$MARLOWE_HOME/drafts.md"
  if [ ! -f "$f" ]; then
    printf '# Drafts — run `marlowe review` to promote to memory.md\n\n' > "$f"
  fi
  printf -- '- [%s] %s\n' "$(date +%Y-%m-%d)" "$text" >> "$f"
  _bump draft
  ok "drafted: $text"
}

cmd_review() {
  # Two-mode review:
  #   light — gather drafts + AI activity bullets, editor-prune, append to memory
  #   smart — LLM proposes a REVISED memory.md (retag + cull + integrate drafts);
  #           editor opens with the proposal; save replaces memory.md
  # Smart mode auto-triggers when memory.md > 4 KiB or when --audit is passed.
  # --no-audit forces light mode.
  local yes_mode=0 force_audit=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --yes)      yes_mode=1; shift ;;
      --audit)    force_audit=1; shift ;;
      --no-audit) force_audit=-1; shift ;;
      *) shift ;;
    esac
  done

  local drafts="$MARLOWE_HOME/drafts.md"
  local activities="$MARLOWE_HOME/activities.md"
  local memory="$MARLOWE_HOME/memory.md"

  # Mode selection: smart iff memory > 4 KiB or --audit, AND claude available.
  local audit_mode=0
  if [ "$force_audit" -eq 1 ]; then
    audit_mode=1
  elif [ "$force_audit" -ne -1 ] && [ -f "$memory" ]; then
    local _mem_size
    _mem_size="$(wc -c < "$memory" 2>/dev/null || echo 0)"
    [ "$_mem_size" -gt 4096 ] && audit_mode=1
  fi
  if [ $audit_mode -eq 1 ] && ! command -v claude >/dev/null 2>&1; then
    say "audit wanted but claude CLI not on PATH — falling back to light review"
    audit_mode=0
  fi

  if [ $audit_mode -eq 1 ]; then
    _smart_review "$drafts" "$activities" "$memory" "$yes_mode"
    return $?
  fi

  local tmp
  tmp="$(mktemp)"
  {
    echo "# Review — delete lines you DON'T want. Save + close to promote the rest."
    echo "# Lines not starting with '- ' are ignored."
    echo
    if [ -f "$drafts" ]; then
      grep -E '^- ' "$drafts" 2>/dev/null || true
    fi
    # Ask claude for additional candidates from recent activities
    if command -v claude >/dev/null 2>&1 && [ -f "$activities" ] && [ -s "$activities" ]; then
      local recent
      recent="$(tail -50 "$activities" 2>/dev/null || true)"
      if [ -n "$recent" ]; then
        local prompt
        prompt="You are helping with end-of-session review.
Below are activity log entries (cd into repos, git commits). Propose 1-5
candidate facts the user MAY want remembered but has not explicitly flagged.
Focus on dead ends (tried then reverted), implicit patterns, surprising
findings. Each candidate ≤120 chars. Format: - <bullet>.
If nothing is worth keeping, output exactly: NONE

Activity log:
$recent"
        local ai
        ai="$(printf '%s' "$prompt" | claude -p 2>/dev/null || true)"
        if [ -n "$ai" ] && [ "$ai" != "NONE" ]; then
          grep -E '^- ' <<< "$ai" 2>/dev/null || true
        fi
      fi
    fi
  } > "$tmp"

  local n=0
  if grep -qE '^- ' "$tmp" 2>/dev/null; then
    n="$(grep -cE '^- ' "$tmp")"
  fi
  if [ "$n" -eq 0 ]; then
    rm -f "$tmp"
    say "nothing to review (no drafts, no AI proposals)"
    return 0
  fi

  say "$n candidate(s) queued — opening \${EDITOR:-vi} (delete unwanted lines, save to promote)"
  if [ $yes_mode -eq 0 ]; then
    "${EDITOR:-vi}" "$tmp"
  fi

  local kept
  kept="$(grep -E '^- ' "$tmp" 2>/dev/null || true)"
  rm -f "$tmp"

  local count=0
  if [ -n "$kept" ]; then
    count="$(printf '%s\n' "$kept" | grep -cE '^- ' || echo 0)"
    {
      printf '\n## Reviewed %s\n' "$(date +%Y-%m-%d)"
      printf '%s\n' "$kept"
    } >> "$memory"
    ok "promoted $count candidate(s) to memory.md"
  else
    say "nothing promoted"
  fi

  # Clear drafts whether or not anything was promoted — the review decision
  # is complete either way.
  printf '# Drafts — run `marlowe review` to promote to memory.md\n\n' > "$drafts"

  _bump review
  cmd_save "review: $count -> memory" --quiet
}

cmd_edit() {
  local f="$MARLOWE_HOME/preferences.md"
  [ -f "$f" ] || die "no preferences.md — run 'marlowe init'"
  local before after
  before="$(stat -c %Y "$f" 2>/dev/null || stat -f %m "$f" 2>/dev/null || echo 0)"
  "${EDITOR:-vi}" "$f"
  after="$(stat -c %Y "$f" 2>/dev/null || stat -f %m "$f" 2>/dev/null || echo 0)"
  if [ "$before" != "$after" ]; then
    if confirm "save changes (commit + push + re-apply)?"; then
      cmd_save "edit preferences"
    else
      say "skipped save — run 'marlowe save' when ready"
    fi
  fi
}

_repo_state() {
  # echoes short git state: "<short-sha> (<branch>, <clean|dirty>[, ahead N][, behind N])"
  local d="$1"
  [ -d "$d/.git" ] || { printf 'no git'; return; }
  local sha branch dirty ahead behind
  sha="$(git -C "$d" rev-parse --short HEAD 2>/dev/null || echo '?')"
  branch="$(git -C "$d" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
  [ -z "$(git -C "$d" status --porcelain 2>/dev/null)" ] && dirty='clean' || dirty='dirty'
  local out="$sha ($branch, $dirty"
  if git -C "$d" rev-parse --abbrev-ref '@{u}' >/dev/null 2>&1; then
    ahead="$(git -C "$d"  rev-list --count '@{u}..HEAD' 2>/dev/null || echo 0)"
    behind="$(git -C "$d" rev-list --count 'HEAD..@{u}' 2>/dev/null || echo 0)"
    [ "$ahead"  -gt 0 ] && out="$out, ahead $ahead"
    [ "$behind" -gt 0 ] && out="$out, behind $behind"
  fi
  printf '%s)' "$out"
}

_mtime_ago() {
  # echoes "Nm ago" or "Nh ago" or "Nd ago"; empty if file missing
  local f="$1" m now diff
  [ -f "$f" ] || { printf ''; return; }
  m="$(stat -c %Y "$f" 2>/dev/null || stat -f %m "$f" 2>/dev/null)"
  now="$(date +%s)"; diff=$((now - m))
  if   [ $diff -lt 60 ];    then printf '%ds ago' "$diff"
  elif [ $diff -lt 3600 ];  then printf '%dm ago' $((diff/60))
  elif [ $diff -lt 86400 ]; then printf '%dh ago' $((diff/3600))
  else                           printf '%dd ago' $((diff/86400))
  fi
}

_has_marlowe_block() {
  grep -q '<!-- marlowe:begin -->' "$1" 2>/dev/null
}

_block_bytes() {
  # Emit byte count of the marlowe:begin..marlowe:end region of $1, or 0.
  [ -f "$1" ] || { printf '0'; return; }
  awk '
    /<!-- marlowe:begin -->/ {inside=1}
    inside { len += length($0) + 1 }
    /<!-- marlowe:end -->/   {print len; exit}
  ' "$1" 2>/dev/null || printf '0'
}

_budget_marker() {
  # Given byte count, emit a pink "!" or "!!" based on soft/hard thresholds.
  local n="$1"
  if   [ "$n" -gt 32768 ]; then printf ' %s!!%s hard' "$PINK" "$RESET"
  elif [ "$n" -gt 8192  ]; then printf ' %s!%s heavy' "$PINK" "$RESET"
  fi
}

cmd_status() {
  printf '%s⟡ marlowe status%s\n\n' "$PINK" "$RESET"

  # Identity
  local prefs="$MARLOWE_HOME/preferences.md"
  if [ -f "$prefs" ]; then
    local user_name assistant_name
    user_name="$(awk -F': *'      '/^[[:space:]]*user_name:/      {print $2; exit}' "$prefs")"
    assistant_name="$(awk -F': *' '/^[[:space:]]*assistant_name:/ {print $2; exit}' "$prefs")"
    printf '%sidentity%s   %s · %s\n'    "$DIM" "$RESET" "${user_name:-?}" "${assistant_name:-?}"
  else
    printf '%sidentity%s   %snot initialized%s — run: marlowe init\n' "$DIM" "$RESET" "$PINK" "$RESET"
  fi

  # Data repo
  printf '%sdata%s       %s  %s\n' \
    "$DIM" "$RESET" "$MARLOWE_HOME" "$(_repo_state "$MARLOWE_HOME")"

  # Framework
  printf '%sframework%s  %s  %s\n' \
    "$DIM" "$RESET" "$MARLOWE_FRAMEWORK" "$(_repo_state "$MARLOWE_FRAMEWORK")"

  # Adapters — show block byte count (what the AI actually pays for per session)
  printf '\n%sadapters%s\n' "$DIM" "$RESET"
  local path ago size
  # claude
  path="$HOME/.claude/CLAUDE.md"
  if _has_marlowe_block "$path"; then
    ago="$(_mtime_ago "$path")"
    size="$(_block_bytes "$path")"
    printf '  %s✓%s claude    %s  (%s, %dB block)%s\n' \
      "$PINK" "$RESET" "$path" "$ago" "$size" "$(_budget_marker "$size")"
  else
    printf '  %s·%s claude    not applied\n' "$DIM" "$RESET"
  fi
  # codex
  path="$HOME/.codex/AGENTS.md"
  if _has_marlowe_block "$path"; then
    ago="$(_mtime_ago "$path")"
    size="$(_block_bytes "$path")"
    printf '  %s✓%s codex     %s  (%s, %dB block)%s\n' \
      "$PINK" "$RESET" "$path" "$ago" "$size" "$(_budget_marker "$size")"
  else
    printf '  %s·%s codex     not applied\n' "$DIM" "$RESET"
  fi
  # cursor (rendered file, paste-manually — whole file IS the block)
  path="$MARLOWE_HOME/generated/cursor-rules.md"
  if [ -f "$path" ]; then
    ago="$(_mtime_ago "$path")"
    size="$(wc -c < "$path")"
    printf '  %s⊙%s cursor    %s  (%s, %dB, paste manually)%s\n' \
      "$PINK" "$RESET" "$path" "$ago" "$size" "$(_budget_marker "$size")"
  else
    printf '  %s·%s cursor    not rendered\n' "$DIM" "$RESET"
  fi

  # Memory
  printf '\n%smemory%s     ' "$DIM" "$RESET"
  if [ -f "$MARLOWE_HOME/memory.md" ]; then
    local mem_count
    mem_count="$(grep -cE '^- \[' "$MARLOWE_HOME/memory.md" 2>/dev/null || echo 0)"
    printf '%s entries  %s\n' "$mem_count" "$MARLOWE_HOME/memory.md"
  else
    printf '%s·%s none\n' "$DIM" "$RESET"
  fi

  # Telemetry: top counters (if any)
  if [ -f "$MARLOWE_HOME/.counters" ]; then
    local top
    top="$(sort -k2 -nr "$MARLOWE_HOME/.counters" 2>/dev/null | head -3 \
             | awk '{printf "%s=%s ", $1, $2}')"
    [ -n "$top" ] && printf '%scounters%s   %s\n' "$DIM" "$RESET" "$top"
  fi

  # Activities (raw, gitignored log — drains into memory via `marlowe distill`)
  printf '%sactivity%s   ' "$DIM" "$RESET"
  if [ -f "$MARLOWE_HOME/activities.md" ]; then
    local act_count act_ago
    act_count="$(grep -cE '^\[' "$MARLOWE_HOME/activities.md" 2>/dev/null || echo 0)"
    act_ago="$(_mtime_ago "$MARLOWE_HOME/activities.md")"
    if [ "$act_count" -gt 50 ]; then
      printf '%s lines (last %s) %s·%s consider: marlowe distill\n' \
        "$act_count" "$act_ago" "$PINK" "$RESET"
    else
      printf '%s lines (last %s)\n' "$act_count" "$act_ago"
    fi
  else
    printf '%s·%s no log yet — run: marlowe wire\n' "$DIM" "$RESET"
  fi

  # Claude statusLine wiring
  printf '\n%sstatusline%s '"$DIM"'(Claude Code)'"$RESET"'  ' "$DIM" "$RESET"
  if grep -Eq 'marlowe.*statusline|statusline[-.]' "$HOME/.claude/settings.json" 2>/dev/null; then
    printf '%s✓%s wired\n' "$PINK" "$RESET"
  else
    printf '%s·%s not wired — see README\n' "$DIM" "$RESET"
  fi
}

cmd_doctor() {
  # One-shot diagnostic — answers "why isn't it working?" with a concrete list.
  # Exit non-zero if any critical check fails so CI / cron can trust it.
  printf '%s⟡ marlowe doctor%s\n\n' "$PINK" "$RESET"
  local fails=0

  _check_ok()   { printf '  %s✓%s %s\n' "$PINK" "$RESET" "$1"; }
  _check_warn() { printf '  %s·%s %s  %s— %s%s\n' "$DIM" "$RESET" "$1" "$DIM" "$2" "$RESET"; }
  _check_fail() { printf '  %s!%s %s  %s— %s%s\n' "$PINK" "$RESET" "$1" "$DIM" "$2" "$RESET"; fails=$((fails+1)); }

  # PATH: marlowe itself (hooks depend on this)
  if command -v marlowe >/dev/null 2>&1; then
    _check_ok "marlowe on PATH — hooks can fire"
  else
    _check_fail "marlowe NOT on PATH" "run: mkdir -p ~/.local/bin && ln -sf '$MARLOWE_FRAMEWORK/bin/marlowe' ~/.local/bin/marlowe  (B1/B2 no-op until fixed)"
  fi

  # PATH: claude (for distill)
  if command -v claude >/dev/null 2>&1; then
    _check_ok "claude on PATH — distill available"
  else
    _check_warn "claude not on PATH" "marlowe distill will error; rest of marlowe unaffected"
  fi

  # MARLOWE_HOME initialized
  if [ -d "$MARLOWE_HOME/.git" ]; then
    _check_ok "data repo initialized at $MARLOWE_HOME"
  else
    _check_fail "data repo not initialized" "run: marlowe init"
  fi

  # MARLOWE_FRAMEWORK present
  if [ -d "$MARLOWE_FRAMEWORK" ]; then
    _check_ok "framework at $MARLOWE_FRAMEWORK"
  else
    _check_fail "framework dir missing" "expected $MARLOWE_FRAMEWORK — re-run install.sh"
  fi

  # memory.md size budget (soft 4 KiB — forces visibility before adapter bloat)
  local mem="$MARLOWE_HOME/memory.md"
  if [ -f "$mem" ]; then
    local mem_size
    mem_size="$(wc -c < "$mem")"
    if [ "$mem_size" -gt 4096 ]; then
      _check_warn "memory.md is ${mem_size}B (>4K soft budget)" "shows up as adapter block bloat; consider distill/compaction"
    else
      _check_ok "memory.md is ${mem_size}B (under 4K)"
    fi
  fi

  # preferences.md present and non-placeholder
  local prefs="$MARLOWE_HOME/preferences.md"
  if [ -f "$prefs" ]; then
    if grep -q '__[A-Z_]*__' "$prefs" 2>/dev/null; then
      _check_fail "preferences.md has unresolved placeholders" "run: marlowe init --force"
    else
      _check_ok "preferences.md resolved"
    fi
  else
    _check_fail "preferences.md missing" "run: marlowe init"
  fi

  # B2: core.hooksPath -> framework/hooks
  local want="$MARLOWE_FRAMEWORK/hooks"
  local got
  got="$(git config --global --get core.hooksPath 2>/dev/null || true)"
  if [ "$got" = "$want" ]; then
    _check_ok "git core.hooksPath -> $want (B2 wired)"
  elif [ -z "$got" ]; then
    _check_warn "git core.hooksPath unset (B2 off)" "run: marlowe wire"
  else
    _check_warn "git core.hooksPath -> $got (B2 off: not our hooks)" "manually merge or re-run marlowe wire"
  fi

  # B1: shell rc sources shell/marlowe.sh
  local rc
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    [ -f "$rc" ] || continue
    if grep -qF "$MARLOWE_FRAMEWORK/shell/marlowe.sh" "$rc" 2>/dev/null; then
      _check_ok "shell hook in $rc (B1 wired)"
      break
    fi
  done
  if ! grep -qlF "$MARLOWE_FRAMEWORK/shell/marlowe.sh" "$HOME/.bashrc" "$HOME/.zshrc" 2>/dev/null; then
    _check_warn "shell hook not sourced (B1 off)" "run: marlowe wire"
  fi

  # Adapters applied to at least one tool
  local adapted=0
  for p in "$HOME/.claude/CLAUDE.md" "$HOME/.codex/AGENTS.md"; do
    if [ -f "$p" ] && grep -q '<!-- marlowe:begin -->' "$p" 2>/dev/null; then
      adapted=$((adapted + 1))
    fi
  done
  if [ "$adapted" -gt 0 ]; then
    _check_ok "$adapted tool(s) have marlowe block injected"
  else
    _check_warn "no adapters applied" "run: marlowe sync (or: marlowe apply <tool>)"
  fi

  printf '\n'
  if [ $fails -eq 0 ]; then
    printf '  %s✓%s all critical checks passed\n' "$PINK" "$RESET"
    return 0
  fi
  printf '  %s!%s %d critical failure(s) — address items above\n' "$PINK" "$RESET" "$fails"
  return 1
}

cmd_help() {
  cat <<EOF
marlowe — portable AI context

  init [--force]              interactive setup wizard
  status                      one-glance health check
  add <type> <text…>          append a structured entry
                                types: lingo | ai-lingo | preference | project
                                auto-commits + pushes
  edit                        open preferences.md in \$EDITOR; offers auto-save
  remember <fact…>            append a dated bullet to memory.md (auto-commits + pushes)
  save [-m <msg>]             commit + push + re-apply adapters (no-op if clean)
  lint [--warn-only]          validate preferences.md
  sync                        pull private repo, re-apply all adapters
  apply <tool>                re-run one adapter (claude | codex | cursor)
  doctor                      environment / install diagnostic
  project add [--from-cwd]    register a project (pointer + 80-char brief)
  project list                list known projects; ● marks active
  project active              print the active project name for \$PWD
  project remove <name>       unregister a project
  project brief <name> <txt>  update a project's 80-char brief
  project activate <name>     force active (overrides \$PWD match)
  project activate --clear    drop the override; resume \$PWD matching
  activity <msg>              fast, lockless append to activities.md (local-only log)
  draft <text>                queue a candidate for next `marlowe review`
  review [--yes] [--audit]    promote drafts; auto-audits (LLM retag+cull) if
                              memory > 4K. --audit forces it, --no-audit skips.
  wire [shell-rc]             install shell + git hooks for auto-capture
  distill [--if-over N]       LLM-compress activities.md into memory.md bullets
EOF
}

cmd="${1:-help}"; shift || true
case "$cmd" in
  # Read-side + fast-path (no lock): activity is an atomic single-line append,
  # called from shell hooks many times per session; must not block.
  init)     cmd_init     "$@" ;;
  status)   cmd_status   "$@" ;;
  lint)     cmd_lint     "$@" ;;
  doctor)   cmd_doctor   "$@" ;;
  activity) cmd_activity "$@" ;;
  draft)    cmd_draft    "$@" ;;
  wire)     cmd_wire     "$@" ;;
  # Write-side: serialize per-host via flock.
  add)      _with_lock cmd_add      "$@" ;;
  project)  _with_lock cmd_project  "$@" ;;
  edit)     _with_lock cmd_edit     "$@" ;;
  remember) _with_lock cmd_remember "$@" ;;
  save)     _with_lock cmd_save     "$@" ;;
  sync)     _with_lock cmd_sync     "$@" ;;
  apply)    _with_lock cmd_apply    "$@" ;;
  distill)  _with_lock cmd_distill  "$@" ;;
  review)   _with_lock cmd_review   "$@" ;;
  help|*) cmd_help ;;
esac
